{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solpbc.org/schemas/transparency-latest/v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chain_length",
    "product",
    "schema",
    "signed_at",
    "tip_sha256",
    "valid_until",
    "version"
  ],
  "properties": {
    "chain_length": {
      "type": "integer",
      "minimum": 1
    },
    "product": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "schema": {
      "const": "https://solpbc.org/schemas/transparency-latest/v1.json"
    },
    "signed_at": {
      "$ref": "#/$defs/utc_second"
    },
    "tip_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "valid_until": {
      "$ref": "#/$defs/utc_second"
    },
    "version": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9.+-]*$"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "utc_second": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}
