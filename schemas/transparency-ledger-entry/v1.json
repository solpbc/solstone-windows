{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solpbc.org/schemas/transparency-ledger-entry/v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifacts",
    "manifests",
    "prev_sha256",
    "prev_version",
    "product",
    "proofs",
    "published_utc",
    "schema",
    "seq",
    "source_commit",
    "version"
  ],
  "properties": {
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "manifests": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/named_digest"
      }
    },
    "prev_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "prev_version": {
      "$ref": "#/$defs/version_or_empty"
    },
    "product": {
      "$ref": "#/$defs/product"
    },
    "proofs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/named_digest"
      }
    },
    "published_utc": {
      "$ref": "#/$defs/utc_second"
    },
    "schema": {
      "const": "https://solpbc.org/schemas/transparency-ledger-entry/v1.json"
    },
    "seq": {
      "type": "integer",
      "minimum": 1
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "version": {
      "$ref": "#/$defs/version"
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bytes",
        "name",
        "sha256"
      ],
      "properties": {
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "name": {
          "$ref": "#/$defs/filename"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "named_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sha256"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/filename"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "filename": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*$"
    },
    "product": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "utc_second": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "version": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9.+-]*$"
    },
    "version_or_empty": {
      "type": "string",
      "pattern": "^(?:|[A-Za-z0-9][A-Za-z0-9.+-]*)$"
    }
  }
}
