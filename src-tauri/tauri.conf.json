{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solstone",
  "version": "0.2.7",
  "identifier": "app.solstone.windows",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "Local-first solstone observer for Windows",
    "longDescription": "A per-user, tray-resident solstone observer: it gathers screen and system audio (plus microphone when present) into local, owner-controlled segments for the owner's journal."
  },
  "plugins": {}
}
