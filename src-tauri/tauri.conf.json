{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solstone",
  "version": "0.2.11",
  "identifier": "app.solstone.windows",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "sol for Windows — part of solstone.",
    "longDescription": "sol runs quietly in the tray, takes in your screen and system audio (plus the microphone when present), and keeps it in local, owner-controlled segments for your journal."
  },
  "plugins": {}
}
